DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coide

COIDE_AUTH_SECRET=change-this-to-a-long-random-secret-32-plus-chars
COIDE_TOKEN_TTL_SECONDS=3600
COIDE_SESSION_TTL_SECONDS=3600
COIDE_VERIFY_TOKEN_TTL_SECONDS=1800
COIDE_CORS_ORIGINS=http://localhost:5173
COIDE_BACKEND_PUBLIC_URL=http://localhost:8000
COIDE_FRONTEND_PUBLIC_URL=http://localhost:5173
COIDE_REQUIRE_EMAIL_VERIFICATION=true
COIDE_ALLOW_DEV_EMAIL_BYPASS=false
COIDE_EMAIL_DELIVERABILITY_CHECK=true
COIDE_RATE_LIMIT_WINDOW_MINUTES=15
COIDE_RATE_LIMIT_MAX_ATTEMPTS_PER_EMAIL=8
COIDE_RATE_LIMIT_MAX_ATTEMPTS_PER_IP=30

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
